# ===== S3 连接配置 =====
# 修改为你的 S3 集群地址（SeaweedFS S3 网关默认 8333 端口）
S3_ENDPOINT=http://127.0.0.1:8333
S3_REGION=us-east-1
S3_BUCKET=testec
S3_ACCESS_KEY=321
S3_SECRET_KEY=321
# path-style：自建集群通常为 true（endpoint/bucket/key）
S3_USE_PATH_STYLE=true
# 启动时幂等创建桶
S3_CREATE_BUCKET=true
# 跳过自签名 TLS 证书校验；仅适合自建/内网，生产或公网请设为 false
S3_SKIP_TLS_VERIFY=true

# ===== 运行模式 =====
# write = 只压写, read = 只压读, both = 先写后读, clean = 清理当前 RUN_ID 对象
MODE=both
# 本轮测试 ID；为空自动生成。read/clean 单独运行时建议显式指定上次 RUN_ID
RUN_ID=

# ===== 写入参数 =====
WRITE_CONCURRENCY=16
# 单对象大小：支持 B/KB/MB/GB（1024 进制）
OBJECT_SIZE=1MB
# 混合对象大小；为空时只使用 OBJECT_SIZE。示例：4KB:70%,1MB:20%,64MB:10%
OBJECT_SIZE_PATTERN=
# 总上传量；对象数 = TOTAL_SIZE / 平均对象大小（OBJECT_SIZE，或 OBJECT_SIZE_PATTERN 的加权平均）
TOTAL_SIZE=1GB

# ===== 查询参数 =====
READ_CONCURRENCY=16
# 读负载类型，可混合：get,head,range,list
READ_OPS=get
# range 读取大小；0 = 使用对象大小
RANGE_SIZE=0
# 读取请求总数；0 = 读「对象数」次（对象随机有放回抽取，非逐个遍历）
READ_COUNT=0
# 按时长持续压读（如 30s）；>0 时优先于 READ_COUNT
READ_DURATION=0
# 读预热时长，不计入正式统计
WARMUP_DURATION=0

# ===== 通用 =====
# 实时指标打印间隔
REPORT_INTERVAL=2s
# 单请求超时
HTTP_TIMEOUT=60s
# 工具侧重试次数；SDK 内部重试关闭
RETRY=0
# 对象 key 基础前缀；实际会拼成 KEY_PREFIX/RUN_ID/xxxx
KEY_PREFIX=s3bench/
# 压测结束后是否清理本轮对象
CLEAN_AFTER=false
# JSON 结果输出路径；为空不输出
RESULT_FILE=
